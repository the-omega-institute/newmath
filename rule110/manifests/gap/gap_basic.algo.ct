ASSERTIONS 14
case ingap_empty_domain_empty:        input=011101111111111                   ; ingap=yes  ; expected_certificate=10000001100000101000001110000101100001101000011110001000100010011000101010001011100011001000110110001110
case ingap_domain_depth_one:          input=01101011101111101110111011        ; ingap=yes  ; expected_certificate=10000001100000101000010010000110100001111000100010001010100010111000110010001101100011101001000010010001100100101001010010010101100101101001100010011001
case ingap_two_probe_empty:           input=01100101110110101111110101101011  ; ingap=yes  ; expected_certificate=100000011000001010000101100001111000100010001001100010111000110010001110100100001001000110010010100100111001010010010101100101111001100110011010100111001001111010011111
case ingap_domain_too_small:          input=0111011101111101110111011         ; ingap=no   ; expected_certificate=10000001100000101000001110000101100001101000011110001001100010101000101110001100100011011000111110010000100100011001001110010100100101011001011110011000
case ingap_wrong_signature:           input=011010111011111011111011          ; ingap=no   ; expected_certificate=100000011000001010000100100001101000011110001000100010101000101110001100100011011000111010010000100100011001001010010011100101001001011010010111
case ingap_wrong_pkg:                 input=011010111011111011101111          ; ingap=no   ; expected_certificate=100000011000001010000100100001101000011110001000100010101000101110001100100011011000111010010000100100011001001010010100100101011001011010010111
case ingap_trailing_input:            input=0111011111111111011               ; ingap=no   ; expected_certificate=10000001100000101000001110000101100001101000011110001000100010011000101010001011100011001000110110001110100011111001000110010010
case comp_all_empty_true:             input=1011111111101011                  ; comp=yes   ; expected_certificate=10000000100000101000001110000100100001011000011010000111100010001000100110001010100011001000111010001111
case comp_chain_true:                 input=10111011101101011101011           ; comp=yes   ; expected_certificate=10000000100000101000001110000100100001101000011110001000100010101000101110001101100011111001000010010001100100111001010110010110
case comp_deep_true:                  input=1011010111001110001011101011      ; comp=yes   ; expected_certificate=1000000010000010100000111000010110000111100010001000100110001100100011011000111010010010100101001001010110010110100110001001101010011011
case comp_missing_first:              input=1011101110110101101011            ; comp=no    ; expected_certificate=100000001000001010000011100001001000011010000111100010001000101010001011100011011000111110010000100100101001010010010101
case comp_missing_second:             input=1011101110110101110011            ; comp=no    ; expected_certificate=100000001000001010000011100001001000011010000111100010001000101010001011100011011000111110010000100100011001010010010101
case comp_bad_relation_event:         input=10111111111011                    ; comp=no    ; expected_certificate=100000001000001010000011100001001000010110000110100001111000100010001001100010101000110010001101
case unknown_tag:                     input=001111                            ; reject=yes ; expected_certificate=10000010100000111000010010000101
