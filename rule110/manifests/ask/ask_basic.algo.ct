ASSERTIONS 12
case p0_empty_b0_ev0:          input=101111011011           ; ask_holds=yes ; expected_certificate=100000010000101000011100010010001011000111100100010010101001011
case p0_e0_b1_ev1:             input=101101110111011        ; ask_holds=yes ; expected_certificate=10000001000010100001110001011000110100011110010011001010100101110011011001110
case p1_empty_b1_ev1:          input=010111110111011        ; ask_holds=yes ; expected_certificate=10000011000011100010010001011000110100011110010011001010100101110011011001110
case p1_e0_b0_ev0:             input=01011011011011         ; ask_holds=yes ; expected_certificate=100000110000111000100100011010001111001001100101010011001001101
case p2_e1e0_b0_ev0:           input=00101110011011011      ; ask_holds=yes ; expected_certificate=1000010100010010001011000110100100110010101001100100110110011111010000
case p3_e0e1e1_b0_ev0:         input=00010110101011011011   ; ask_holds=yes ; expected_certificate=10000111000101100011010010001001010100110010011011001111101000010100101010011
case p0_empty_wrong_mark:      input=1011111011011          ; ask_holds=no  ; expected_certificate=1000000100001010000111000100100010110001101001000100100110010111001100
case p0_empty_wrong_evidence:  input=1011110111011          ; ask_holds=no  ; expected_certificate=1000000100001010000111000100100010110001111001000100100110010111001100
case p1_empty_wrong_mark:      input=01011110111011         ; ask_holds=no  ; expected_certificate=1000001100001110001001000101100011010010001001001100101010011001001101
case p1_e0_wrong_evidence:     input=010110110111011        ; ask_holds=no  ; expected_certificate=1000001100001110001001000110100011110010011001010100101110011011001110
case malformed_probe:          input=1111011011             ; ask_holds=no  ; expected_certificate=10000001000001100001010000111000101100011010010001001001
case trailing_input:           input=10111101101111         ; ask_holds=no  ; expected_certificate=10000001000010100001110001001000101100011110010001001010100101110011001001101
