# msame_symm.enum.ct
# Theorem: msame_symm : forall {m n : BMark}, msame m n -> msame n m
# Strategy: enumerate 4 cases. Vacuous when msame(m,n) is false (b0_b1 / b1_b0).
PRODUCTIONS 0
ASSERTIONS 4
case b0_b0: input=011011  ; conclusion_holds=trivial
case b0_b1: input=0111011 ; conclusion_holds=vacuous (msame(b0,b1) is false)
case b1_b0: input=1011011 ; conclusion_holds=vacuous (msame(b1,b0) is false)
case b1_b1: input=10111011; conclusion_holds=trivial
