# Host-owned BEDC pipeline configuration template.
#
# Copy to .bedc/host.env (gitignored) and fill the machine-specific values.
# These facts belong to the host repository, NOT to the consensus-rnd skill's
# .refactor-loop/ runtime directory. Host tools (tools/host_context.py,
# tools/sync_with_auto_dev.py, tools/auto_heal_base.py,
# tools/verification_contract.py) read from .bedc/host.env or the process
# environment; values set in the process environment take precedence.
#
# Branch topology mirrors the BEDC dev-sync pipeline described in CLAUDE.md
# (codex-auto-dev / auto-dev / dev). Override per host as needed.

# Lean mirror-port base branch.
export BEDC_LEAN_BASE_BRANCH="lean4-codex-auto-dev"

# Pipeline branch where codex workers push.
export BEDC_PIPELINE_BRANCH="codex-auto-dev"

# Shared mirror branch.
export BEDC_MIRROR_BRANCH="auto-dev"

# Upstream integration branch.
export BEDC_UPSTREAM_BRANCH="dev"

# Absolute path to the codex CLI on this machine (machine-specific).
export BEDC_CODEX_PATH="/path/to/codex"

# Scratch worktree used by sync validation (machine-specific; tmp is fine).
export BEDC_SYNC_VALIDATION_WORKTREE="/tmp/.bedc_sync_validate_wt"
