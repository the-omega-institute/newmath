{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-omega-institute.github.io/newmath/schemas/bio-reality/conjecture.schema.json",
  "title": "BioReality conjecture packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "conjecture_id",
    "biological_object",
    "informal_statement",
    "bedc_minimal_form",
    "claimed_layer",
    "evidence_basis",
    "reality_contact_refs",
    "probe_refs",
    "forbidden_claims",
    "null_reason"
  ],
  "properties": {
    "conjecture_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "biological_object": {
      "type": "string",
      "minLength": 1
    },
    "informal_statement": {
      "type": "string",
      "minLength": 1
    },
    "bedc_minimal_form": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "carrier",
        "distinctions",
        "readback",
        "internal_structure"
      ],
      "properties": {
        "carrier": {
          "type": "string",
          "minLength": 1
        },
        "distinctions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readback": {
          "type": "string",
          "minLength": 1
        },
        "internal_structure": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "coordinate",
              "closure",
              "spectrum",
              "trigger",
              "rank",
              "homology",
              "relation",
              "none"
            ]
          }
        }
      }
    },
    "claimed_layer": {
      "type": "string",
      "enum": [
        "code_read",
        "orf_eligibility",
        "translation_realization",
        "structural_order",
        "physical_admissibility",
        "function_realization",
        "system_phenotype",
        "cross_layer_relation"
      ]
    },
    "evidence_basis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "external_reality",
          "bedc_coordinate",
          "bedc_closure",
          "bedc_spectrum",
          "derived_probe",
          "mismatch_ledger",
          "mechanism_bridge"
        ]
      }
    },
    "reality_contact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._:-]*$"
      }
    },
    "probe_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._:-]*$"
      }
    },
    "forbidden_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "null_reason": {
      "type": "string"
    }
  }
}
