{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-omega-institute.github.io/newmath/schemas/bio-reality/mismatch.schema.json",
  "title": "BioReality mismatch packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mismatch_id",
    "probe_ref",
    "contact_ref",
    "status",
    "mismatch_kind",
    "observed_delta",
    "refinement_pressure",
    "blocked_claims",
    "null_reason"
  ],
  "properties": {
    "mismatch_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "probe_ref": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "contact_ref": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "aligned",
        "partially_aligned",
        "mismatch",
        "underdetermined",
        "blocked_null"
      ]
    },
    "mismatch_kind": {
      "type": "string",
      "enum": [
        "coordinate_failure",
        "scope_too_large",
        "missing_context",
        "external_data_bias",
        "mechanism_gap",
        "conjecture_overclaim",
        "none"
      ]
    },
    "observed_delta": {
      "type": "string",
      "minLength": 1
    },
    "refinement_pressure": {
      "type": "string",
      "minLength": 1
    },
    "blocked_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "null_reason": {
      "type": "string"
    }
  }
}
