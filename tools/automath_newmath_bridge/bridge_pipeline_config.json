{
  "version": 1,
  "description": "Growth-aware discovery rules for the Automath-NewMath bridge runner. The runner observes Git refs, emits reviewable transfer candidates, and optionally updates local bridge state.",
  "required_branch": "bridge/newmath-automath-consumption",
  "state_path": "tools/automath_newmath_bridge/state/bridge_state.json",
  "inbox_path": "tools/automath_newmath_bridge/inbox/bridge_inbox.jsonl",
  "transfer_plan_path": "tools/automath_newmath_bridge/out/bridge_transfer_plan.md",
  "synthesis_report_path": "tools/automath_newmath_bridge/out/bridge_synthesis_report.md",
  "sync_from_auto_dev": {
    "enabled": true,
    "source_ref": "origin/auto-dev",
    "strategy": "merge",
    "merge_args": ["--no-edit"]
  },
  "merge_back_after_gates": {
    "enabled": true,
    "mode": "scoped_paths",
    "target_worktree": "newmath-bedc-bridge-worktree",
    "target_branch": "bedc-claim-packet-pipeline",
    "source_ref": "bridge/newmath-automath-consumption",
    "scoped_paths": [
      "tools/bedc-deep/BOARD.md",
      "tools/bedc-deep/prompts/board_judge.txt",
      "tools/bedc-deep/prompts/codex_track_attempt.txt",
      "tools/bedc-deep/prompts/oracle_initial.txt",
      "docs/bridge/automath-board-continuation-ledger.md",
      "docs/bridge/automath-newmath-ack.jsonl",
      "docs/bridge/automath-newmath-failures.jsonl",
      "docs/bridge/automath-newmath-production-status.md",
      "tools/automath_newmath_bridge/review_packets/README.md",
      "tools/automath_newmath_bridge/review_packets"
    ]
  },
  "bedc_board_ingest": {
    "enabled": true,
    "gate_results_path": "tools/automath_newmath_bridge/out/bridge_gate_results.jsonl",
    "review_packet_dir": "tools/automath_newmath_bridge/review_packets",
    "ledger_path": "docs/bridge/automath-board-continuation-ledger.md",
    "ack_ledger_path": "docs/bridge/automath-newmath-ack.jsonl",
    "status_report_path": "docs/bridge/automath-newmath-production-status.md",
    "max_candidates_per_pass": 3,
    "fit_threshold": 7,
    "novelty_threshold": 6,
    "apply_by_default": false
  },
  "bedc_failure_feedback": {
    "enabled": true,
    "state_dir": "tools/bedc-deep/state",
    "output_path": "docs/bridge/automath-newmath-failures.jsonl"
  },
  "repositories": {
    "automath": {
      "repo": "the-omega-institute/automath",
      "local_path": "../automath",
      "default_ref": "origin/dev",
      "bridge_ref": "bridge/automath-newmath-consumption"
    },
    "newmath": {
      "repo": "the-omega-institute/newmath",
      "local_path": ".",
      "default_ref": "origin/auto-dev",
      "integration_ref": "origin/codex-auto-dev",
      "bridge_ref": "bridge/newmath-automath-consumption"
    }
  },
  "discovery_rules": [
    {
      "id": "newmath.bedc_supervisor_pipeline",
      "source_repo_key": "newmath",
      "source_ref": "origin/auto-dev",
      "include_globs": ["tools/bedc-deep/supervisor.py"],
      "exclude_globs": [],
      "source_artifact_kind": "pipeline_status",
      "destination_repo_key": "automath",
      "destination_ref": "bridge/automath-newmath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/newmath/{slug}.json",
      "destination_artifact_kind": "pipeline_status",
      "bridge_direction": "newmath_to_automath",
      "status": "observed",
      "operator_review_required": true,
      "taste_gate_required": false,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 95,
      "notes": "NewMath BEDC supervisor logic is the bridge model for low-water refill, loning watch, reject clustering, PI review, and gated writes.",
      "next_action": "compare supervisor patterns before changing bridge automation or writeback policy"
    },
    {
      "id": "newmath.pending_proposals",
      "source_repo_key": "newmath",
      "source_ref": "origin/auto-dev",
      "include_globs": ["papers/bedc/proposals/*.md"],
      "exclude_globs": ["papers/bedc/proposals/README.md", "papers/bedc/proposals/accepted/*", "papers/bedc/proposals/rejected/*"],
      "source_artifact_kind": "proposal",
      "destination_repo_key": "automath",
      "destination_ref": "bridge/automath-newmath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/newmath/{slug}.json",
      "destination_artifact_kind": "review_packet",
      "bridge_direction": "newmath_to_automath",
      "status": "needs_operator_review",
      "operator_review_required": true,
      "taste_gate_required": true,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 90,
      "notes": "New BEDC proposal detected; Automath may use the proposal pattern only after operator review.",
      "next_action": "operator review proposal and decide whether Automath should consume the mechanism"
    },
    {
      "id": "newmath.accepted_proposals",
      "source_repo_key": "newmath",
      "source_ref": "origin/auto-dev",
      "include_globs": ["papers/bedc/proposals/accepted/*.md"],
      "exclude_globs": [],
      "source_artifact_kind": "accepted_proposal",
      "destination_repo_key": "automath",
      "destination_ref": "bridge/automath-newmath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/newmath/{slug}.json",
      "destination_artifact_kind": "review_packet",
      "bridge_direction": "newmath_to_automath",
      "status": "candidate",
      "operator_review_required": true,
      "taste_gate_required": true,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 80,
      "notes": "Accepted BEDC proposal detected; still requires destination review before Automath consumption.",
      "next_action": "map accepted proposal fields to an Automath proposal/writeback gate or leave observed"
    },
    {
      "id": "newmath.real_constant_lean",
      "source_repo_key": "newmath",
      "source_ref": "origin/auto-dev",
      "include_globs": ["lean4/BEDC/Derived/**/*.lean"],
      "exclude_globs": [],
      "content_regex": "RealConstant|constant|Constant",
      "source_artifact_kind": "lean_theorem",
      "destination_repo_key": "automath",
      "destination_ref": "bridge/automath-newmath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/newmath/{slug}.json",
      "destination_artifact_kind": "candidate_mechanism",
      "bridge_direction": "newmath_to_automath",
      "status": "observed",
      "operator_review_required": true,
      "taste_gate_required": true,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 88,
      "notes": "NewMath constant/RealConstant Lean material has emerged; bridge must keep TasteGate and destination audit boundaries before Automath consumption.",
      "next_action": "synthesize with Automath Killo/golden and autoresearch surfaces; do not write Automath paper or Lean yet"
    },
    {
      "id": "newmath.real_constant_paper",
      "source_repo_key": "newmath",
      "source_ref": "origin/auto-dev",
      "include_globs": ["papers/bedc/parts/concrete_instances/**/*.tex"],
      "exclude_globs": [],
      "content_regex": "RealConstant|constant rational|constant-rational|Constant",
      "source_artifact_kind": "paper_claim",
      "destination_repo_key": "automath",
      "destination_ref": "bridge/automath-newmath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/newmath/{slug}.json",
      "destination_artifact_kind": "candidate_mechanism",
      "bridge_direction": "newmath_to_automath",
      "status": "observed",
      "operator_review_required": true,
      "taste_gate_required": true,
      "audit_required": true,
      "external_publication_risk": "low",
      "priority": 84,
      "notes": "NewMath paper-side constant material is source evidence only until Automath chooses a concrete receiving queue and gate.",
      "next_action": "review source theorem labels, TasteGate/audit status, and Automath readiness before creating any writeback packet"
    },
    {
      "id": "newmath.ai_seed_stubs",
      "source_repo_key": "newmath",
      "source_ref": "origin/codex-auto-dev",
      "include_globs": ["papers/bedc/parts/concrete_instances/*_namecert_construction.tex"],
      "exclude_globs": [],
      "content_regex": "\\\\origin\\{ai\\}",
      "source_artifact_kind": "paper_seed_stub",
      "destination_repo_key": "automath",
      "destination_ref": "bridge/automath-newmath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/newmath/{slug}.json",
      "destination_artifact_kind": "scope_ledger",
      "bridge_direction": "newmath_to_automath",
      "status": "candidate",
      "operator_review_required": true,
      "taste_gate_required": true,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 75,
      "notes": "AI-origin BEDC seed-stub detected; bridge use must preserve seedClosure and TasteGate boundary.",
      "next_action": "record whether Automath has consumed the lifecycle pattern; do not promote content automatically"
    },
    {
      "id": "newmath.taste_gate_witnesses",
      "source_repo_key": "newmath",
      "source_ref": "origin/codex-auto-dev",
      "include_globs": ["lean4/BEDC/Derived/**/TasteGate.lean"],
      "exclude_globs": [],
      "content_regex": "def\\s+taste_gate\\b",
      "source_artifact_kind": "taste_gate_witness",
      "destination_repo_key": "automath",
      "destination_ref": "bridge/automath-newmath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/newmath/{slug}.json",
      "destination_artifact_kind": "scope_ledger",
      "bridge_direction": "newmath_to_automath",
      "status": "candidate",
      "operator_review_required": true,
      "taste_gate_required": true,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 85,
      "notes": "BEDC TasteGate witness detected; may inform Automath gate design after review.",
      "next_action": "cite exact witness if any bridged AI-origin chapter pattern leaves seed status"
    },
    {
      "id": "automath.pipeline_gate_surfaces",
      "source_repo_key": "automath",
      "source_ref": "origin/dev",
      "include_globs": [
        "lean4/scripts/omega_ci.py",
        "lean4/scripts/codex_formalize.py",
        "tools/distillation/distill.py",
        "tools/distillation/supervisor.py",
        "tools/chatgpt-oracle/oracle_pipeline.py"
      ],
      "exclude_globs": [],
      "source_artifact_kind": "pipeline_status",
      "destination_repo_key": "newmath",
      "destination_ref": "bridge/newmath-automath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/automath/{slug}.json",
      "destination_artifact_kind": "pipeline_status",
      "bridge_direction": "automath_to_newmath",
      "status": "candidate",
      "operator_review_required": true,
      "taste_gate_required": false,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 78,
      "notes": "Automath has existing gates for Lean audit, formalization loops, distillation writeback, and staged oracle/publication flow.",
      "next_action": "reuse these gates when deciding whether Automath evidence can become a NewMath review packet"
    },
    {
      "id": "automath.killo_and_golden_lean",
      "source_repo_key": "automath",
      "source_ref": "origin/dev",
      "include_globs": ["lean4/Omega/**/*Killo*.lean", "lean4/Omega/**/*Golden*.lean", "lean4/Omega/**/*golden*.lean"],
      "exclude_globs": ["lean4/Omega/POM.lean", "lean4/Omega/Folding.lean", "lean4/Omega/Zeta.lean"],
      "source_artifact_kind": "lean_theorem",
      "destination_repo_key": "newmath",
      "destination_ref": "bridge/newmath-automath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/automath/{slug}.json",
      "destination_artifact_kind": "candidate_mechanism",
      "bridge_direction": "automath_to_newmath",
      "status": "candidate",
      "operator_review_required": true,
      "taste_gate_required": false,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 70,
      "notes": "Automath Killo/golden Lean evidence detected; NewMath may consume as research-object source material after review.",
      "next_action": "select exact theorem labels and decide destination research object"
    },
    {
      "id": "automath.distillation_writeback_artifacts",
      "source_repo_key": "automath",
      "source_ref": "origin/dev",
      "include_globs": ["backflow/**/writebacks.json", "backflow/**/writeback_ledger.json", "theory/**/writeback_ledger.json"],
      "exclude_globs": [],
      "source_artifact_kind": "writeback_packet",
      "destination_repo_key": "newmath",
      "destination_ref": "bridge/newmath-automath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/automath/{slug}.json",
      "destination_artifact_kind": "candidate_mechanism",
      "bridge_direction": "automath_to_newmath",
      "status": "candidate",
      "operator_review_required": true,
      "taste_gate_required": false,
      "audit_required": true,
      "external_publication_risk": "none",
      "priority": 65,
      "notes": "Automath writeback packet detected; NewMath may use failure or accepted writeback structure as task-generation input after review.",
      "next_action": "inspect review gate status before mapping to a NewMath proposal or task"
    },
    {
      "id": "automath.paper_claim_sources",
      "source_repo_key": "automath",
      "source_ref": "origin/dev",
      "include_globs": ["theory/**/*.tex", "papers/publication/**/*.tex"],
      "exclude_globs": ["**/build/**", "**/.quarto/**"],
      "content_regex": "\\\\label\\{(thm|prop|cor|lem|def|con|bridge):",
      "source_artifact_kind": "paper_claim",
      "destination_repo_key": "newmath",
      "destination_ref": "bridge/newmath-automath-consumption",
      "destination_path_template": "tools/automath_newmath_bridge/inbox/automath/{slug}.json",
      "destination_artifact_kind": "open_problem_target",
      "bridge_direction": "automath_to_newmath",
      "status": "candidate",
      "operator_review_required": true,
      "taste_gate_required": false,
      "audit_required": true,
      "external_publication_risk": "low",
      "priority": 45,
      "notes": "Automath paper claim source detected; NewMath may consume only after choosing a concrete research-object destination.",
      "next_action": "use omega_ci paper coverage before promoting any claim-derived bridge item"
    }
  ]
}
